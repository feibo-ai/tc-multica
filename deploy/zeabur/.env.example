# Zeabur production env var names (project teamctx). Set real values in the
# Zeabur dashboard per service — this file documents the NAMES only, no secrets.
# See ./README.md for the full table and wiring.

# ── multica-backend ───────────────────────────────────────────────────────
DATABASE_URL=${POSTGRES_CONNECTION_STRING}?sslmode=disable   # Zeabur ref → postgresql
PORT=8080
APP_ENV=production
MULTICA_PUBLIC_URL=https://api.teamctx.actionow.ai
MULTICA_APP_URL=https://teamctx.actionow.ai
FRONTEND_ORIGIN=https://teamctx.actionow.ai
CORS_ALLOWED_ORIGINS=https://teamctx.actionow.ai
COOKIE_DOMAIN=.actionow.ai
ALLOW_SIGNUP=true
MULTICA_CONTROL_PLANE_ENABLED=true
JWT_SECRET=__secret__
MULTICA_SECRET_MASTER_KEY=__secret_base64_32_bytes__
RESEND_API_KEY=__secret__
RESEND_FROM_EMAIL=noreply@actionow.ai

# ── multica-web ───────────────────────────────────────────────────────────
PORT=3000
HOSTNAME=0.0.0.0
REMOTE_API_URL=http://multica-backend.zeabur.internal:8080
# Do NOT set NEXT_PUBLIC_WS_URL (origin fallback + /ws rewrite handle WS).
# Do NOT set ZBPACK_DOCKERFILE_NAME (image-type service, no source build).

# ── GitHub Actions (deploy repo) ──────────────────────────────────────────
# secret  ZEABUR_TOKEN   = <Zeabur API token>
# variable ZEABUR_ENV_ID = 6a1800dd5245baf7fc3dd7cc
